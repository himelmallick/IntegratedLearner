Package: IntegratedLearner
Type: Package
Title: Integrated Multi-Omics Learning for Survival and Other Outcomes
Version: 0.99.0
Authors@R: c(
    person("Nalin", "Arora", email = "naa4050@med.cornell.edu", role = "aut"),
